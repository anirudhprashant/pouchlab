                "custom_liquid_c6QWpW": {
                  "type": "custom-liquid",
                  "name": "Saver",
                  "settings": {
                    "custom_liquid": "{% assign vendor_handle = product.vendor | handleize %}\n{% assign brand_collection = collections[vendor_handle] %}\n\n{% if brand_collection.metafields.custom.pack_pricing and product.available %}\n  {% assign pricing = brand_collection.metafields.custom.pack_pricing.value %}\n  \n  {% comment %} Calculate savings and convert to pence for Shopify's money filters {% endcomment %}\n  {% assign savings = product.price | divided_by: 100.0 | minus: pricing.pack_10 | times: 10 %}\n  {% assign savings_formatted = savings | times: 100 | money_without_trailing_zeros %}\n  \n  <style>\n    .inline-savings-tag {\n      display: inline-flex;\n      align-items: center;\n      background: #fef08a; \n      color: #854d0e; \n      padding: 4px 10px;\n      border-radius: 6px;\n      font-family: inherit;\n      font-size: 13px;\n      font-weight: 700;\n      letter-spacing: 0.5px;\n      margin-top: -5px;\n    }\n  <\/style>\n\n  <div class=\"inline-savings-tag\">\n    🔥 Save {{ savings_formatted }} with a Pack of 10\n  <\/div>\n{% endif %}"
                  },
                  "blocks": {}
