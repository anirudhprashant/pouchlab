    "custom_liquid_EB7zPP": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<style>\n  .nic-howto-wrapper {\n    width: 100%;\n    max-width: 1200px;\n    margin: 40px auto;\n    padding: 0 15px;\n    box-sizing: border-box;\n    font-family: inherit;\n  }\n\n  .nic-howto-heading {\n    text-align: center;\n    font-size: 24px;\n    font-weight: 700;\n    margin-bottom: 30px;\n    color: #000000;\n  }\n\n  .nic-howto-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 20px;\n  }\n\n  .nic-step-card {\n    background: #ffffff;\n    border: 1px solid #e5e5e5;\n    border-radius: 12px;\n    padding: 30px 20px;\n    text-align: center;\n    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);\n    transition: transform 0.3s ease, box-shadow 0.3s ease;\n  }\n  \n  .nic-step-card:hover {\n    transform: translateY(-4px);\n    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);\n  }\n\n  .nic-step-icon-wrapper {\n    width: 60px;\n    height: 60px;\n    background: #000000; \/* Sleek black *\/\n    border-radius: 50px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin: 0 auto 20px;\n    position: relative;\n  }\n\n  \/* High-contrast monochrome step badge *\/\n  .nic-step-badge {\n    position: absolute;\n    top: -4px;\n    right: -4px;\n    background: #ffffff; \n    color: #000000;\n    font-weight: 800;\n    font-size: 12px;\n    width: 24px;\n    height: 24px;\n    border-radius: 50%;\n    border: 2px solid #000000;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .nic-step-icon-wrapper svg {\n    width: 30px;\n    height: 30px;\n    stroke: #ffffff; \/* Sharp white lines *\/\n    stroke-width: 2;\n    fill: none;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .nic-step-title {\n    font-size: 18px;\n    font-weight: 700;\n    margin: 0 0 10px 0;\n    color: #000000;\n  }\n\n  .nic-step-desc {\n    font-size: 14px;\n    color: #555555;\n    margin: 0;\n    line-height: 1.5;\n  }\n\n  \/* Keeps it looking elegant as cards stack on mobile *\/\n  @media (max-width: 768px) {\n    .nic-howto-wrapper {\n      margin: 30px auto;\n    }\n    .nic-howto-heading {\n      font-size: 22px;\n      margin-bottom: 20px;\n    }\n    .nic-howto-grid {\n      grid-template-columns: 1fr;\n      gap: 15px;\n    }\n    .nic-step-card {\n      padding: 24px 20px;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n    }\n  }\n<\/style>\n\n<div class=\"nic-howto-wrapper\">\n  <h3 class=\"nic-howto-heading\">How to Use Nicotine Pouches<\/h3>\n  \n  <div class=\"nic-howto-grid\">\n    \n    <div class=\"nic-step-card\">\n      <div class=\"nic-step-icon-wrapper\">\n        <div class=\"nic-step-badge\">1<\/div>\n        <svg viewBox=\"0 0 24 24\">\n          <path d=\"M7 10v.01M17 10v.01M3 14c3.5 4.5 14.5 4.5 18 0\" \/>\n        <\/svg>\n      <\/div>\n      <h4 class=\"nic-step-title\">Park It<\/h4>\n      <p class=\"nic-step-desc\">Take a pouch out of the can and tuck it comfortably between your upper lip and gum.<\/p>\n    <\/div>\n\n    <div class=\"nic-step-card\">\n      <div class=\"nic-step-icon-wrapper\">\n        <div class=\"nic-step-badge\">2<\/div>\n        <svg viewBox=\"0 0 24 24\">\n          <circle cx=\"12\" cy=\"12\" r=\"10\" \/>\n          <path d=\"M12 6v6l4 2\" \/>\n        <\/svg>\n      <\/div>\n      <h4 class=\"nic-step-title\">Feel the Tingle<\/h4>\n      <p class=\"nic-step-desc\">Enjoy a steady, discreet release of flavor and nicotine for up to 30-60 minutes.<\/p>\n    <\/div>\n\n    <div class=\"nic-step-card\">\n      <div class=\"nic-step-icon-wrapper\">\n        <div class=\"nic-step-badge\">3<\/div>\n        <svg viewBox=\"0 0 24 24\">\n          <path d=\"M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2\" \/>\n        <\/svg>\n      <\/div>\n      <h4 class=\"nic-step-title\">Bin It<\/h4>\n      <p class=\"nic-step-desc\">Once you're done, simply throw the pouch in the bin or store it in the can's top catch lid.<\/p>\n    <\/div>\n\n  <\/div>\n<\/div>",
        "color_scheme": "scheme-7",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 7
      }
    },
