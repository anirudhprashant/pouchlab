            "custom_liquid_karRRF": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<style>\n  .trust-markers-grid {\n    display: grid;\n    \/* Keeps a neat 2x2 grid on both desktop and mobile *\/\n    grid-template-columns: repeat(2, 1fr); \n    gap: 12px;\n    margin: 20px 0;\n    width: 100%;\n    box-sizing: border-box;\n  }\n\n  .trust-card {\n    background-color: #ffffff;\n    border: 1px solid #e5e5e5;\n    border-radius: 12px;\n    padding: 18px 12px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    text-align: center;\n    gap: 10px;\n    transition: all 0.3s ease;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.02);\n  }\n\n  \/* Premium hover state: lifting the card and darkening the border *\/\n  .trust-card:hover {\n    border-color: #000000;\n    transform: translateY(-3px);\n    box-shadow: 0 6px 15px rgba(0,0,0,0.06);\n  }\n\n  .trust-icon {\n    width: 26px;\n    height: 26px;\n    color: #000000;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .trust-icon svg {\n    width: 100%;\n    height: 100%;\n    stroke: currentColor;\n    stroke-width: 1.5;\n    fill: none;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .trust-text {\n    font-family: inherit;\n    font-size: 13px;\n    font-weight: 600;\n    color: #111111;\n    margin: 0;\n    line-height: 1.2;\n    letter-spacing: 0.3px;\n  }\n\n  \/* Tweaks for a tighter mobile layout *\/\n  @media (max-width: 768px) {\n    .trust-markers-grid {\n      gap: 10px;\n    }\n    .trust-card {\n      padding: 14px 10px;\n      border-radius: 10px;\n    }\n    .trust-icon {\n      width: 22px;\n      height: 22px;\n    }\n    .trust-text {\n      font-size: 12px;\n    }\n  }\n<\/style>\n\n<div class=\"trust-markers-grid\">\n  \n  <div class=\"trust-card\">\n    <div class=\"trust-icon\">\n      <svg viewBox=\"0 0 24 24\">\n        <path d=\"M2 12h20M12 2v20M20 16l-4-4 4-4M4 8l4 4-4 4M16 4l-4 4-4-4M8 20l4-4 4 4\"\/>\n      <\/svg>\n    <\/div>\n    <p class=\"trust-text\">Refreshing Flavor<\/p>\n  <\/div>\n\n  <div class=\"trust-card\">\n    <div class=\"trust-icon\">\n      <svg viewBox=\"0 0 24 24\">\n        <path d=\"M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z\"\/>\n        <line x1=\"7\" y1=\"7\" x2=\"7.01\" y2=\"7\"\/>\n      <\/svg>\n    <\/div>\n    <p class=\"trust-text\">Great value<\/p>\n  <\/div>\n\n  <div class=\"trust-card\">\n    <div class=\"trust-icon\">\n      <svg viewBox=\"0 0 24 24\">\n        <polygon points=\"13 2 3 14 12 14 11 22 21 10 12 10 13 2\"\/>\n      <\/svg>\n    <\/div>\n    <p class=\"trust-text\">Quick Satisfaction<\/p>\n  <\/div>\n\n  <div class=\"trust-card\">\n    <div class=\"trust-icon\">\n      <svg viewBox=\"0 0 24 24\">\n        <path d=\"M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\"\/>\n        <polyline points=\"3.27 6.96 12 12.01 20.73 6.96\"\/>\n        <line x1=\"12\" y1=\"22.08\" x2=\"12\" y2=\"12\"\/>\n      <\/svg>\n    <\/div>\n    <p class=\"trust-text\">Discreet & Portable<\/p>\n  <\/div>\n\n<\/div>"
              },
              "blocks": {}
