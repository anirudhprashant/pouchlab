{% doc %}
  @prompt
    Create a video gallery section that displays 9:16 aspect ratio vertical videos in a horizontal scrollable row, stacked right next to each other with minimal spacing. The section should support multiple videos that can scroll horizontally, similar to a social media story feed layout. Each video should maintain the 9:16 portrait aspect ratio and be positioned directly adjacent to the next video. Include settings to add multiple video URLs, customize the section heading, and control the number of videos displayed. The design should be clean and modern with smooth scrolling functionality., Instead of uploading video URLs, I should be able to just use the media section in Shopify, so I should be able to pick an image from the gallery. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-gallery-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-video-gallery__container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-video-gallery__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin: 0 20px 30px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-video-gallery__scroll-container-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.scrollbar_color }} transparent;
  }

  .ai-video-gallery__scroll-container-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 8px;
  }

  .ai-video-gallery__scroll-container-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  .ai-video-gallery__scroll-container-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background-color: {{ block.settings.scrollbar_color }};
    border-radius: 4px;
  }

  .ai-video-gallery__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.video_spacing }}px;
    padding: 0 20px;
  }

  .ai-video-gallery__video-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.video_width }}px;
    height: calc({{ block.settings.video_width }}px * 16 / 9);
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    background-color: #000000;
  }

  .ai-video-gallery__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-video-gallery__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    position: relative;
  }

  .ai-video-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    max-width: 120px;
    max-height: 120px;
    opacity: 0.3;
  }

  .ai-video-gallery__placeholder-text-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    color: #999999;
    font-size: 12px;
    text-align: center;
    padding: 0 20px;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-video-gallery__video-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_video_width }}px;
      height: calc({{ block.settings.mobile_video_width }}px * 16 / 9);
    }

    .ai-video-gallery__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<video-gallery-{{ ai_gen_id }} class="ai-video-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-gallery__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-video-gallery__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-video-gallery__scroll-container-{{ ai_gen_id }}">
      <div class="ai-video-gallery__track-{{ ai_gen_id }}">
        {% for i in (1..9) %}
          {% liquid
            assign video_key = 'video_' | append: i
            assign video = block.settings[video_key]
          %}

          {% if video != blank %}
            <div class="ai-video-gallery__video-wrapper-{{ ai_gen_id }}">
              {% if video.media_type == 'video' %}
                {{ video | video_tag: 
                  autoplay: block.settings.autoplay, 
                  loop: block.settings.loop, 
                  muted: block.settings.muted, 
                  controls: block.settings.show_controls,
                  class: 'ai-video-gallery__video-' | append: ai_gen_id
                }}
              {% elsif video.media_type == 'external_video' %}
                <video
                  class="ai-video-gallery__video-{{ ai_gen_id }}"
                  {% if block.settings.autoplay %}autoplay{% endif %}
                  {% if block.settings.loop %}loop{% endif %}
                  {% if block.settings.muted %}muted{% endif %}
                  playsinline
                  {% if block.settings.show_controls %}controls{% endif %}
                >
                  <source src="{{ video.sources[0].url }}" type="{{ video.sources[0].mime_type }}">
                </video>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}

        {% assign has_videos = false %}
        {% for i in (1..9) %}
          {% liquid
            assign video_key = 'video_' | append: i
            assign video = block.settings[video_key]
          %}
          {% if video != blank %}
            {% assign has_videos = true %}
            {% break %}
          {% endif %}
        {% endfor %}

        {% unless has_videos %}
          <div class="ai-video-gallery__video-wrapper-{{ ai_gen_id }}">
            <div class="ai-video-gallery__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-video-gallery__placeholder-text-{{ ai_gen_id }}">
                Add videos from your media library
              </div>
            </div>
          </div>
          <div class="ai-video-gallery__video-wrapper-{{ ai_gen_id }}">
            <div class="ai-video-gallery__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-video-gallery__placeholder-text-{{ ai_gen_id }}">
                Video 2
              </div>
            </div>
          </div>
          <div class="ai-video-gallery__video-wrapper-{{ ai_gen_id }}">
            <div class="ai-video-gallery__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-video-gallery__placeholder-text-{{ ai_gen_id }}">
                Video 3
              </div>
            </div>
          </div>
        {% endunless %}
      </div>
    </div>
  </div>
</video-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.videos = this.querySelectorAll('.ai-video-gallery__video-{{ ai_gen_id }}');
        this.scrollContainer = this.querySelector('.ai-video-gallery__scroll-container-{{ ai_gen_id }}');
        
        this.setupVideoObserver();
      }

      setupVideoObserver() {
        if (!this.videos.length) return;

        const options = {
          root: this.scrollContainer,
          threshold: 0.5
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            const video = entry.target;
            if (entry.isIntersecting) {
              if (video.paused && {{ block.settings.autoplay | json }}) {
                video.play().catch(() => {});
              }
            } else {
              if (!video.paused) {
                video.pause();
              }
            }
          });
        }, options);

        this.videos.forEach((video) => {
          observer.observe(video);
        });
      }
    }

    customElements.define('video-gallery-{{ ai_gen_id }}', VideoGallery{{ ai_gen_id }});
  })();
</script>

