    },
    {
      "type": "header",
      "content": "Step 3"
    },
    {
      "type": "image_picker",
      "id": "step_3_image",
      "label": "Image"
    },
    {
      "type": "inline_richtext",
      "id": "step_3_title",
      "label": "Title",
      "default": "Enjoy"
    },
    {
      "type": "textarea",
      "id": "step_3_text",
