      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Mobile size",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Tagline"
    },
    {
      "type": "color",
      "id": "tagline_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "tagline_size_desktop",
      "label": "Desktop size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "tagline_size_mobile",
      "label": "Mobile size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Call to action button"
    },
    {
      "type": "color",
      "id": "cta_bg_color",
      "label": "Background",
      "default": "#c3cca6"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "cta_border_color",
      "label": "Border",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "cta_border_width",
