{% comment %}
  How to Use Nicotine Pouches - Visual Guide
  Fully editable in Shopify theme editor
{% endcomment %}

<section class="how-to-use-section color-{{ section.settings.color_scheme }}">
  <div class="section-{{ section.settings.section_width }}">
    {% if section.settings.heading != blank %}
      <div class="section-header">
        <h2 class="section-title {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="section-subtitle">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="steps-container" style="--columns: {{ section.settings.columns }};">
      {% for block in section.blocks %}
        <div class="step-card" {{ block.shopify_attributes }}>
          <div class="step-number">{{ forloop.index }}</div>
          
          {% if block.settings.icon != 'none' %}
            <div class="step-icon">
              {% case block.settings.icon %}
                {% when 'hand' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>
                {% when 'sparkles' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M9 5H5"/><path d="M19 13v4"/><path d="M19 17h4"/></svg>
                {% when 'clock' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {% when 'trash' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
              {% endcase %}
            </div>
          {% endif %}
          
          <h3 class="step-title">{{ block.settings.title }}</h3>
          <p class="step-description">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.show_button and section.settings.button_text != blank and section.settings.button_link != blank %}
      <div class="section-cta">
        <a href="{{ section.settings.button_link }}" class="button {{ section.settings.button_style }}">{{ section.settings.button_text }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
.how-to-use-section {
  width: 100%;
  position: relative;
  background: rgb(var(--color-background));
  padding-block-start: var(--section-padding-top, 64px);
  padding-block-end: var(--section-padding-bottom, 64px);
}

.how-to-use-section .section-page-width,
.how-to-use-section .section-full-width {
  max-width: var(--page-width, 1400px);
  margin: 0 auto;
  padding-inline: 24px;
  box-sizing: border-box;
}

@media screen and (max-width: 640px) {
  .how-to-use-section .section-page-width,
  .how-to-use-section .section-full-width {
    padding-inline: 16px;
  }
}

.section-header {
  text-align: center;
  margin-bottom: 48px;
}

.section-title {
  margin-bottom: 12px;
}

.section-subtitle {
  color: var(--color-foreground-muted);
  max-width: 500px;
  margin: 0 auto;
}

.steps-container {
  display: grid;
  grid-template-columns: repeat(var(--columns, 4), 1fr);
  gap: 24px;
}

@media screen and (max-width: 990px) {
  .steps-container {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 640px) {
  .steps-container {
    grid-template-columns: 1fr;
  }
}

.step-card {
  position: relative;
  text-align: center;
  padding: 40px 24px 32px;
  background: transparent;
  border: 1px solid color-mix(in srgb, var(--color-border) 45%, transparent);
  border-radius: 10px;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.step-card:hover {
  transform: none;
  box-shadow: none;
}

.step-number {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  width: 28px;
  height: 28px;
  background: var(--color-primary);
  color: var(--color-primary-button-text);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 0.875rem;
}

.step-icon {
  width: 48px;
  height: 48px;
  margin: 0 auto 16px;
  color: var(--color-foreground);
  opacity: 0.7;
}

.step-icon svg {
  width: 100%;
  height: 100%;
}

.step-title {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 8px;
}

.step-description {
  font-size: 0.875rem;
  line-height: 1.6;
  color: var(--color-foreground-muted);
  margin: 0;
}

.section-cta {
  text-align: center;
  margin-top: 40px;
}

/* Add padding to first and last cards */
.step-card:first-child {
  margin-left: 16px;
}

.step-card:last-child {
  margin-right: 16px;
}

/* Mobile carousel - show 1.5 cards */
@media screen and (max-width: 640px) {
  .steps-container {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    gap: 16px;
    padding: 0 16px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  
  .steps-container::-webkit-scrollbar {
    display: none;
  }
  
  .step-card {
    flex: 0 0 65vw;
    max-width: 280px;
    scroll-snap-align: start;
    margin-left: 0 !important;
    margin-right: 0 !important;
  }
  
  .step-card:first-child {
    margin-left: 0;
  }
  
  .step-card:last-child {
    margin-right: 0;
    padding-right: 16px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "How to Use Guide",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to Use Nicotine Pouches"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "New to pouches? Follow these simple steps."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {"value": "h2", "label": "Large"},
        {"value": "h3", "label": "Medium"},
        {"value": "h4", "label": "Small"}
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button",
      "default": false
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Light Strength"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        {"value": "button", "label": "Primary"},
        {"value": "button button--secondary", "label": "Secondary"},
        {"value": "button button--outline", "label": "Outline"}
      ],
      "default": "button"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {"value": "page-width", "label": "Page width"},
        {"value": "full-width", "label": "Full width"}
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-mono-pure"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {"value": "none", "label": "None"},
            {"value": "hand", "label": "Hand (Place)"},
            {"value": "sparkles", "label": "Sparkles (Tingle)"},
            {"value": "clock", "label": "Clock (Time)"},
            {"value": "trash", "label": "Trash (Dispose)"}
          ],
          "default": "hand"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step description",
          "default": "Describe this step here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How to Use Guide",
      "settings": {
        "color_scheme": "scheme-mono-pure",
        "button_link": "/collections/light-strength"
      },
      "blocks": [
        {"type": "step", "settings": {"icon": "hand", "title": "Place the Pouch", "description": "Put one pouch between your upper lip and gum. Position it comfortably to the side."}},
        {"type": "step", "settings": {"icon": "sparkles", "title": "Feel the Tingle", "description": "You'll feel a slight tingling as the nicotine releases. This is normal and means it's working."}},
        {"type": "step", "settings": {"icon": "clock", "title": "Enjoy 20-60 Minutes", "description": "Keep the pouch in place for 20-60 minutes. No spitting needed — completely spit-free."}},
        {"type": "step", "settings": {"icon": "trash", "title": "Dispose Responsibly", "description": "Remove and throw in a bin. The can has a compartment for used pouches when you're out."}}
      ]
    }
  ]
}
{% endschema %}
