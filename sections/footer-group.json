        "custom_liquid_YeWyyH": {
          "type": "custom-liquid",
          "name": "t:names.custom_liquid",
          "settings": {
            "custom_liquid": "<style>\n  .global-age-warning-bar {\n    \/* Forces the bar to stretch to the absolute edges of the screen *\/\n    width: 100vw;\n    position: relative;\n    left: 50%;\n    right: 50%;\n    margin-left: -50vw;\n    margin-right: -50vw;\n    \n    \/* Sleek, authoritative styling *\/\n    background-color: #000000; \n    color: #ffffff;\n    text-align: center;\n    padding: 14px 20px;\n    box-sizing: border-box;\n    border-top: 1px solid #222222; \n    border-bottom: 1px solid #222222;\n  }\n\n  .age-warning-header {\n    font-family: inherit;\n    font-size: 13px;\n    font-weight: 800;\n    letter-spacing: 1.5px;\n    margin: 0 0 6px 0;\n    text-transform: uppercase;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n  }\n\n  .age-warning-body {\n    font-family: inherit;\n    font-size: 13px;\n    font-weight: 500;\n    margin: 0;\n    color: #a3a3a3; \/* Soft grey creates visual hierarchy *\/\n    line-height: 1.5;\n    letter-spacing: 0.3px;\n  }\n\n  \/* Keeps the emoji crisp *\/\n  .age-warning-icon {\n    font-size: 16px;\n    line-height: 1;\n  }\n\n  \/* Tighter layout for mobile screens *\/\n  @media (max-width: 768px) {\n    .global-age-warning-bar {\n      padding: 12px 15px;\n    }\n    .age-warning-header {\n      font-size: 12px;\n      letter-spacing: 1px;\n    }\n    .age-warning-body {\n      font-size: 11px;\n    }\n  }\n<\/style>\n\n<div class=\"global-age-warning-bar\">\n  <p class=\"age-warning-header\">\n    <span class=\"age-warning-icon\">⚠️<\/span> AGE RESTRICTED PRODUCT | 18+ ONLY\n  <\/p>\n  <p class=\"age-warning-body\">\n    This product contains nicotine. Nicotine is an addictive substance. Sale to persons under 18 years of age is prohibited.\n  <\/p>\n<\/div>"
          },
          "blocks": {}
        }
      },
