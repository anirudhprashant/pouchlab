{% comment %}
  Newsletter Section with Discount Incentive
  Email capture with 10% off offer
{% endcomment %}

<section class="newsletter-section color-{{ section.settings.color_scheme }}">
  <div class="section-{{ section.settings.section_width }}">
    <div class="newsletter-content">
      {% if section.settings.badge_text != blank %}
        <div class="newsletter-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
          <span>{{ section.settings.badge_text | escape }}</span>
        </div>
      {% endif %}

      <h2 class="newsletter-heading">{{ section.settings.heading | escape }}</h2>
      <p class="newsletter-subheading">{{ section.settings.subheading | escape }}</p>

      {% form 'customer', class: 'newsletter-form' %}
        {% if form.posted_successfully? %}
          <div class="newsletter-success">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            <span>{{ section.settings.success_message | escape }}</span>
          </div>
        {% else %}
          <div class="newsletter-input-group">
            <input
              type="email"
              name="contact[email]"
              class="newsletter-input"
              placeholder="{{ section.settings.placeholder | escape }}"
              required
              aria-label="Email address"
            >
            <button type="submit" class="button newsletter-submit">
              {{ section.settings.button_text | escape }}
            </button>
          </div>

          {% if form.errors %}
            <div class="newsletter-error">{{ form.errors | default_errors }}</div>
          {% endif %}
        {% endif %}
      {% endform %}

      <p class="newsletter-disclaimer">{{ section.settings.disclaimer | escape }}</p>
    </div>
  </div>
</section>

{% stylesheet %}
  .newsletter-section {
    padding-block-start: var(--section-padding-top, 80px);
    padding-block-end: var(--section-padding-bottom, 80px);
  }

  .newsletter-content {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .newsletter-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 24px;
    color: var(--color-foreground);
  }

  .newsletter-heading {
    margin-bottom: 12px;
  }

  .newsletter-subheading {
    color: var(--color-foreground-muted);
    margin-bottom: 32px;
    line-height: 1.5;
  }

  .newsletter-form {
    margin-bottom: 16px;
  }

  .newsletter-input-group {
    display: flex;
    gap: 12px;
  }

  @media screen and (max-width: 640px) {
    .newsletter-input-group {
      flex-direction: column;
    }
  }

  .newsletter-input {
    flex: 1;
    padding: 14px 18px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 1rem;
    background: var(--color-background);
    color: var(--color-foreground);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-foreground);
  }

  .newsletter-submit {
    white-space: nowrap;
  }

  .newsletter-success {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px;
    background: rgba(var(--color-foreground-rgb), 0.1);
    border-radius: 8px;
    font-weight: 500;
  }

  .newsletter-error {
    margin-top: 12px;
    padding: 12px;
    background: rgba(220, 38, 38, 0.1);
    color: #dc2626;
    border-radius: 8px;
    font-size: 0.875rem;
  }

  .newsletter-disclaimer {
    font-size: 0.75rem;
    color: var(--color-foreground-muted);
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Join 10,000+ subscribers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get 10% Off Your First Order"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Subscribe for exclusive deals and new product alerts."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Get 10% Off"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks! Check your inbox for your discount code."
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "By subscribing, you agree to receive marketing emails. Unsubscribe anytime."
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Newsletter",
      "settings": {
        "color_scheme": "scheme-mono-pure"
      }
    }
  ]
}
{% endschema %}
