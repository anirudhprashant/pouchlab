{% comment %}
  Intro with Value Props - Mobile carousel
  Heading + subtext + 4 value prop cards that carousel on mobile
{% endcomment %}

<section class="intro-value-section color-{{ section.settings.color_scheme }}">
  <div class="section-{{ section.settings.section_width }}">
    {% if section.settings.heading != blank %}
      <div class="section-header">
        <h2 class="section-title {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="section-subtitle">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="value-cards-container">
      {% for block in section.blocks %}
        <div class="value-card" {{ block.shopify_attributes }}>
          <div class="value-card-inner">
            <h3 class="value-card-title">{{ block.settings.title }}</h3>
            <p class="value-card-desc">{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
.intro-value-section {
  padding-block-start: var(--section-padding-top, 64px);
  padding-block-end: var(--section-padding-bottom, 64px);
}

.section-header {
  text-align: center;
  margin-bottom: 40px;
}

.section-title {
  margin-bottom: 12px;
}

.section-subtitle {
  color: var(--color-foreground-muted);
  max-width: 600px;
  margin: 0 auto;
}

.value-cards-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

.value-card {
  background: var(--color-background);
  border: 1px solid var(--color-border);
  border-radius: 10px;
  padding: 20px;
}

.value-card-title {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 8px;
  color: var(--color-foreground);
}

.value-card-desc {
  font-size: 0.875rem;
  line-height: 1.5;
  color: var(--color-foreground-muted);
  margin: 0;
}

/* Mobile carousel - show 1.5 cards */
@media screen and (max-width: 640px) {
  .value-cards-container {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    gap: 12px;
    padding: 0 16px;
    margin: 0 -16px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  
  .value-cards-container::-webkit-scrollbar {
    display: none;
  }
  
  .value-card {
    flex: 0 0 65vw;
    max-width: 260px;
    scroll-snap-align: start;
  }
  
  .value-card:first-child {
    margin-left: 0;
  }
  
  .value-card:last-child {
    margin-right: 16px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Intro with Value Cards",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The UK's Premium Nicotine Pouch Destination"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium nicotine pouches from ZYN, VELO, Nordic Spirit, PABLO, KILLA & more. Fast UK delivery, same-day dispatch, 10,000+ happy customers."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {"value": "h2", "label": "Large"},
        {"value": "h3", "label": "Medium"},
        {"value": "h4", "label": "Small"}
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {"value": "page-width", "label": "Page width"},
        {"value": "full-width", "label": "Full width"}
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "value_card",
      "name": "Value Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Card title",
          "default": "Value Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Card description",
          "default": "Describe the value proposition here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Intro with Value Cards",
      "settings": {
        "heading": "The UK's Premium Nicotine Pouch Destination",
        "subheading": "Premium nicotine pouches from ZYN, VELO, Nordic Spirit, PABLO, KILLA & more. Fast UK delivery, same-day dispatch, 10,000+ happy customers.",
        "color_scheme": "scheme-2"
      },
      "blocks": [
        {"type": "value_card", "settings": {"title": "Free UK Delivery", "description": "On all orders over £20. Same-day dispatch when you order before 2pm."}},
        {"type": "value_card", "settings": {"title": "Same-Day Dispatch", "description": "Order before 2pm and your package ships the same day. 1-2 day UK delivery."}},
        {"type": "value_card", "settings": {"title": "10,000+ Happy Customers", "description": "Join thousands of satisfied UK customers who trust Pouch Lab."}},
        {"type": "value_card", "settings": {"title": "100% Authentic Products", "description": "Only genuine products from licensed manufacturers. No fakes, ever."}}
      ]
    }
  ]
}
{% endschema %}
