

<div class="section-background color-scheme-7"></div>
<aside
  class="announcement-bar trust-bar spacing-style section section--full-width color-scheme-7"
  style="--border-bottom-width: 0px;"
>
  <div class="page-width">
    <div class="trust-bar__content">
      <span class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg> Free UK Delivery £30+</span>
      <span class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> Same-Day Dispatch</span>
      <span class="trust-item trust-item--stars">★★★★★ 10,000+ Reviews</span>
      <span class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg> 100% Authentic</span>
    </div>
  </div>
</aside>

{% stylesheet %}
  .announcement-bar.trust-bar {
    border-block-end: var(--border-bottom-width) solid var(--color-border);
    padding: 8px 0;
  }

  .trust-bar__content {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
    font-size: 0.75rem;
    color: var(--color-foreground);
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }

  .trust-item svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .trust-item--stars {
    color: #f5a623;
    font-weight: 600;
    letter-spacing: 2px;
  }

  @media screen and (max-width: 749px) {
    .trust-bar__content {
      gap: 16px;
      font-size: 0.6875rem;
    }

    .trust-item:nth-child(3),
    .trust-item:nth-child(4) {
      display: none;
    }
  }
{% endstylesheet %}
