{% if request.page_type == 'article' and article.handle == 'how-long-do-nicotine-pouches-last-uk-guide' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How many nicotine pouches can I use per day?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most manufacturers recommend a maximum of 20 pouches per day, but this varies by nicotine strength and individual tolerance. Start with fewer pouches and monitor how you feel."
      }
    },
    {
      "@type": "Question",
      "name": "Can I reuse a nicotine pouch?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Nicotine pouches are designed for single use. Once the nicotine and flavour have been depleted, the pouch should be disposed of responsibly."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if I leave a nicotine pouch in all day?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most of the nicotine will be released within the first hour. After that, the pouch offers minimal effect but may cause gum irritation with prolonged contact. It is not recommended."
      }
    },
    {
      "@type": "Question",
      "name": "Do nicotine pouches stain teeth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Unlike traditional tobacco, quality nicotine pouches are formulated to minimise tooth staining. However, long-term use may cause some discolouration over time."
      }
    }
  ]
}
</script>
{% endif %}

