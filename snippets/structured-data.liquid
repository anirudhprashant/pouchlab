{% comment %}
  Structured data for Pouch Lab.
  Keep homepage FAQ answers aligned with visible homepage copy.
  Product schema is handled in sections/product-information.liquid via Shopify's built-in structured_data output.
{% endcomment %}

{% liquid
  assign shop_url = shop.secure_url | default: shop.url
  assign organization_name = shop.name
  assign same_as_links = ''

  if settings.social_instagram_link != blank
    assign same_as_links = same_as_links | append: settings.social_instagram_link | append: '||'
  endif
  if settings.social_facebook_link != blank
    assign same_as_links = same_as_links | append: settings.social_facebook_link | append: '||'
  endif
  if settings.social_twitter_link != blank
    assign same_as_links = same_as_links | append: settings.social_twitter_link | append: '||'
  endif
  if settings.social_youtube_link != blank
    assign same_as_links = same_as_links | append: settings.social_youtube_link | append: '||'
  endif
  if settings.social_tiktok_link != blank
    assign same_as_links = same_as_links | append: settings.social_tiktok_link | append: '||'
  endif

  assign same_as_array = same_as_links | split: '||' | compact
%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ organization_name | json }},
  "url": {{ shop_url | json }}{% if settings.logo != blank %},
  "logo": {{ settings.logo | image_url: width: 600 | prepend: 'https:' | json }}{% endif %}{% if same_as_array.size > 0 %},
  "sameAs": [
    {% for social_url in same_as_array %}
      {{ social_url | json }}{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]{% endif %}
}
</script>

{% capture search_target %}{{ shop_url }}/search?q={search_term_string}{% endcapture %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": {{ organization_name | json }},
  "url": {{ shop_url | json }},
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": {{ search_target | json }}
    },
    "query-input": "required name=search_term_string"
  }
}
</script>

{% if request.page_type == 'blog' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": {{ blog.title | json }},
    "url": {{ shop_url | append: blog.url | json }}{% if blog.articles_count > 0 %},
    "blogPost": [
      {% for article in blog.articles limit: 10 %}
        {
          "@type": "BlogPosting",
          "headline": {{ article.title | json }},
          "url": {{ shop_url | append: article.url | json }},
          "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]{% endif %}
  }
  </script>
{% endif %}

{% if request.page_type == 'index' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are nicotine pouches?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nicotine pouches are small, tobacco-free pouches that sit between the lip and gum and release nicotine without smoke or vapour. Popular brands on Pouch Lab include VELO, Nordic Spirit, PABLO, KILLA and XQS."
        }
      },
      {
        "@type": "Question",
        "name": "How do I use nicotine pouches?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Place a pouch between your upper lip and gum, leave it in place for around 20 to 60 minutes, then dispose of it responsibly."
        }
      },
      {
        "@type": "Question",
        "name": "What nicotine strength should I choose?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Light strength is usually best for beginners, Medium suits regular users, and Strong or Extra Strong options are better for experienced users with higher nicotine tolerance."
        }
      },
      {
        "@type": "Question",
        "name": "Are nicotine pouches legal in the UK?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nicotine pouches are sold in the UK, but the category is still evolving. ASH notes that nicotine pouches are not currently well regulated in the UK, so it is worth checking current guidance as the rules develop."
        }
      },
      {
        "@type": "Question",
        "name": "How long do nicotine pouches last?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Each pouch typically lasts around 20 to 60 minutes depending on the brand and strength."
        }
      },
      {
        "@type": "Question",
        "name": "Where can I read more about nicotine pouches and stop-smoking support?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For an overview of nicotine pouches, see ASH's nicotine pouches guidance. If you want help quitting smoking, the NHS recommends using your local Stop Smoking Service for support."
        }
      }
    ]
  }
  </script>
{% endif %}

{% if request.page_type == 'collection' %}
  {% assign collection_description = collection.description | strip_html | strip %}
  {% if collection_description == blank %}
    {% capture collection_description %}Shop {{ collection.title }} nicotine pouches at {{ organization_name }}.{% endcapture %}
  {% endif %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": {{ collection.title | json }},
    "description": {{ collection_description | truncate: 300 | json }},
    "url": {{ shop_url | append: collection.url | json }},
    "mainEntity": {
      "@type": "ItemList",
      "numberOfItems": {{ collection.products_count | default: collection.products.size }},
      "itemListElement": [
        {% for product in collection.products limit: 10 %}
          {
            "@type": "ListItem",
            "position": {{ forloop.index }},
            "url": {{ shop_url | append: product.url | json }},
            "item": {
              "@type": "Product",
              "name": {{ product.title | json }},
              "url": {{ shop_url | append: product.url | json }}{% if product.featured_image %},
              "image": {{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }}{% endif %}
            }
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }
  }
  </script>
{% endif %}


{% if request.page_type == 'collection' and collection.handle == 'extra-strong' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What nicotine strength is considered extra strong?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Extra strong nicotine pouches typically contain 12mg or more of nicotine per pouch. In the UK market, this includes products from brands like VELO, KILLA, ICEBERG, Nordic Spirit and PABLO."
      }
    },
    {
      "@type": "Question",
      "name": "Are extra strong nicotine pouches safe?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Extra strong nicotine pouches contain nicotine which is addictive. They are intended for adult smokers and experienced nicotine users only. Not suitable for pregnant women, breastfeeding mothers, or people under 18. Always follow the manufacturer's guidance."
      }
    },
    {
      "@type": "Question",
      "name": "Which UK brands make extra strong nicotine pouches?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Popular UK extra strong brands include VELO, KILLA, PABLO, ICEBERG, Nordic Spirit, FUMI and NICPIX. PouchLab stocks the full range with free UK delivery."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use extra strong nicotine pouches to quit smoking?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Many users transition from smoking to nicotine pouches as a harm-reduction approach. While not marketed as a cessation product, the controlled nicotine delivery can help manage cigarette cravings. Consult your GP for quit-smoking support."
      }
    },
    {
      "@type": "Question",
      "name": "How long do extra strong nicotine pouches last?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most extra strong nicotine pouches last 30 to 60 minutes per pouch, depending on the brand and individual usage patterns. Stronger pouches may have a slightly shorter effective duration."
      }
    },
    {
      "@type": "Question",
      "name": "What's the difference between strong and extra strong nicotine pouches?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Strong nicotine pouches typically contain 10-12mg of nicotine per pouch. Extra strong pouches contain 12mg or more, delivering a noticeably more intense nicotine hit. Extra strong is best suited to regular smokers or experienced pouch users."
      }
    }
  ]
}
</script>
{% endif %}

{% if request.page_type == 'article' and article %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title | json }},
  "description": {{ article.excerpt_or_content | truncate: 300 | json }},
  "image": {% if article.image %}{{ article.image | image_url: width: 1200 | prepend: 'https:' | json }}{% else %}null{% endif %},
  "author": {
    "@type": "Organization",
    "name": {{ shop.name | json }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "logo": {
      "@type": "ImageObject",
      "url": {{ shop.logo | image_url: width: 600 | prepend: 'https:' | json }}
    }
  },
  "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
  "dateModified": {{ article.updated_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": {{ shop.url | append: article.url | json }}
  },
  "url": {{ shop.url | append: article.url | json }}
}
</script>
{% endif %}

{% if request.page_type == 'article' and article %}
{% capture breadcrumb_list %}
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": {{ shop.url | json }}
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Lab Report",
      "item": {{ shop.url | append: '/blogs/lab-report' | json }}
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ article.title | json }},
      "item": {{ shop.url | append: article.url | json }}
    }
  ]
}
{% endcapture %}
<script type="application/ld+json">{{ breadcrumb_list }}</script>
{% endif %}

{% if request.page_type == 'collection' and collection %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": {{ shop.url | json }}
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ collection.title | json }},
      "item": {{ shop.url | append: collection.url | json }}
    }
  ]
}
</script>
{% endif %}

