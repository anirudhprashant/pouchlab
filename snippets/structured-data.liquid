{% if request.page_type == 'article' and article.handle == 'nicotine-pouches-and-alcohol-uk-guide' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Can I use nicotine pouches before driving?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Nicotine pouches do not produce breath alcohol or impair driving in the way alcohol does. However, if you feel dizzy or unwell from combined use, do not drive."
      }
    },
    {
      "@type": "Question",
      "name": "Does using nicotine pouches at the pub make you more drunk?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not directly, but the combination can impair judgment more than alcohol alone. The interaction between alcohol and nicotine is complex and individual - always err on the side of caution."
      }
    },
    {
      "@type": "Question",
      "name": "Will nicotine pouches show up on a breathalyser?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Breathalysers test for alcohol, not nicotine. However, some workplace drug tests do test for nicotine metabolites - check your employer policy if this is a concern."
      }
    },
    {
      "@type": "Question",
      "name": "Why does alcohol make me want to use more nicotine pouches?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Research shows that alcohol consumption increases activity in the brain's reward pathways, making nicotine feel more satisfying. This can create a cycle where each substance reinforces the desire for the other."
      }
    }
  ]
}
</script>
{% endif %}

