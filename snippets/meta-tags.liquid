<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="view-transition"
  content="same-origin"
>
<meta
  name="theme-color"
  content=""
>

{%- liquid
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = shop.metafields.global.description_tag | default: page_description | default: shop.description | default: shop.name
  assign og_title = shop.metafields.global.title_tag | default: page_title | default: shop.name

  if request.page_type == 'product'
    assign og_type = 'product'
    if product.metafields.global.title_tag != blank
      assign og_title = product.metafields.global.title_tag
    else
      assign og_title = product.title | append: ' | Nicotine Pouches UK — Pouch Lab'
    endif
    assign og_description = product.metafields.global.description_tag | default: product.description | strip_html
  elsif request.page_type == 'list-collections'
    assign og_title = 'Nicotine Pouch Collections UK | Pouch Lab'
    assign og_description = shop.metafields.global.description_tag | default: shop.description | default: shop.name
  elsif request.page_type == 'collection'
    if collection.metafields.global.title_tag != blank
      assign og_title = collection.metafields.global.title_tag
    else
      assign og_title = collection.title | append: ' | Nicotine Pouches UK — Pouch Lab'
    endif
    assign og_description = collection.metafields.global.description_tag | default: collection.description | strip_html
  elsif request.page_type == 'article'
    assign og_type = 'article'
    if article.metafields.global.title_tag != blank
      assign og_title = article.metafields.global.title_tag
    else
      assign og_title = article.title | append: ' | Pouch Lab Report'
    endif
    assign og_description = article.metafields.global.description_tag | default: article.excerpt_or_content | strip_html
  elsif request.page_type == 'page'
    if page.metafields.global.title_tag != blank
      assign og_title = page.metafields.global.title_tag
    else
      assign og_title = page.title | append: ' | Pouch Lab'
    endif
    assign og_description = page.metafields.global.description_tag | default: page.content | strip_html
  elsif request.page_type == 'blog'
    assign og_title = 'Pouch Lab Report | Nicotine Pouches Blog UK — Pouch Lab'
    assign og_description = blog.metafields.global.description_tag | default: blog.description | default: shop.metafields.global.description_tag
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if page_image -%}
  <meta
    property="og:image"
    content="http:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:width"
    content="{{ page_image.width }}"
  >
  <meta
    property="og:image:height"
    content="{{ page_image.height }}"
  >
{%- endif -%}

{%- if request.page_type == 'index' -%}
  {%- if shop.image -%}
  <meta property="og:image" content="https:{ shop.image | image_url: width: 1200 }">
  <meta property="og:image:secure_url" content="https:{ shop.image | image_url: width: 1200 }">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  {%- elsif settings.logo -%}
  <meta property="og:image" content="https:{ settings.logo | image_url: width: 1200 }">
  <meta property="og:image:secure_url" content="https:{ settings.logo | image_url: width: 1200 }">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  {%- else -%}
  <meta property="og:image" content="https://cdn.shopify.com/s/files/1/0924/4744/1162/files/plytix-685e5da955f01038f8f4968e-png.webp?v=1772472296">
  <meta property="og:image:secure_url" content="https://cdn.shopify.com/s/files/1/0924/4744/1162/files/plytix-685e5da955f01038f8f4968e-png.webp?v=1772472296">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  {%- endif -%}
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>

{%- liquid
  assign seo_suffix = ' | Nicotine Pouches UK — Pouch Lab'

  if request.page_type == 'index'
    assign seo_title = 'Nicotine Pouches UK | VELO, ZYN & More | Pouch Lab'
  elsif request.page_type == 'list-collections'
    assign seo_title = 'Nicotine Pouch Collections UK | Pouch Lab'
  elsif request.page_type == 'product'
    assign product_strength = product.metafields.custom.strength | default: ''
    if product.metafields.global.title_tag != blank
      assign seo_title = product.metafields.global.title_tag
    elsif product_strength != ''
      assign seo_title = product.title | append: ' | ' | append: product_strength | append: ' | Pouch Lab'
    else
      assign seo_title = product.title | append: seo_suffix
    endif
  elsif request.page_type == 'collection'
    if collection.metafields.global.title_tag != blank
      assign seo_title = collection.metafields.global.title_tag
    else
      assign seo_title = collection.title | append: seo_suffix
    endif
  elsif request.page_type == 'article'
    if article.metafields.global.title_tag != blank
      assign seo_title = article.metafields.global.title_tag
    else
      assign seo_title = article.title | append: ' | Pouch Lab Report'
    endif
  elsif request.page_type == 'page'
    if page.metafields.global.title_tag != blank
      assign seo_title = page.metafields.global.title_tag
    else
      assign seo_title = page.title | append: ' | Pouch Lab'
    endif
  elsif request.page_type == 'blog'
    assign seo_title = 'Pouch Lab Report | Nicotine Pouches Blog UK — Pouch Lab'
  else
    assign seo_title = page_title | append: ' | Pouch Lab'
  endif
%}

<title>{{ seo_title | escape }}</title>

<link
  rel="canonical"
  href="{{ canonical_url }}"
>

<meta
  name="description"
  content="{{ og_description | escape }}"
>
